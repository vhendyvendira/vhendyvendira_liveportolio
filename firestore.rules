rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Analytics: Global Stats
    match /stats/{statId} {
      allow get: if isValidId(statId);
      
      // Allow creation of the global stats doc if it doesn't exist
      allow create: if statId == 'global' 
        && incoming().visitorCount == 1
        && incoming().keys().size() == 1;

      // Allow incrementing the visitor count
      // In a production app, we would strictly link this to the uniqueVisitors creation
      allow update: if statId == 'global'
        && incoming().visitorCount == existing().visitorCount + 1
        && incoming().diff(existing()).affectedKeys().hasOnly(['visitorCount']);
    }

    // Analytics: Unique Visitors
    match /uniqueVisitors/{visitorId} {
      // Allow checking if visitor exists
      allow get: if isValidId(visitorId);
      
      // Allow recording a new unique visitor
      allow create: if isValidId(visitorId)
        && incoming().visitedAt is string
        && incoming().visitedAt.size() <= 64
        && incoming().keys().size() == 1;
    }
  }
}
