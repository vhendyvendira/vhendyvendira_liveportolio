rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Site Stats
    match /stats/{statId} {
      // Global stats
      allow get: if true;
      
      // Only allow incrementing visitorCount by exactly 1
      // We don't use list here as it's a specific document access pattern
      allow update: if (
        statId == 'global' &&
        request.resource.data.keys().hasAll(['visitorCount']) &&
        request.resource.data.keys().size() == 1 &&
        request.resource.data.visitorCount is number &&
        request.resource.data.visitorCount == resource.data.visitorCount + 1
      );

      // Initialization - normally handled by admin or a one-time script
      // But for simplicity in this demo, we can allow create if it starts at 0 or 1
      allow create: if (
        statId == 'global' &&
        request.resource.data.keys().hasAll(['visitorCount']) &&
        request.resource.data.keys().size() == 1 &&
        request.resource.data.visitorCount == 1
      );
    }
  }
}
